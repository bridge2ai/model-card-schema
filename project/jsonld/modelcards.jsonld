      "name": "licenses",
      "definition_uri": "https://w3id.org/linkml/modelcard/licenses",
      "description": "License information",
      "from_schema": "https://w3id.org/linkml/modelcard",
      "slot_uri": "https://w3id.org/linkml/modelcard/licenses",
      "owner": "ModelDetails",
      "domain_of": [
