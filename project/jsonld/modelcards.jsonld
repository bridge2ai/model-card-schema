      "from_schema": "https://w3id.org/linkml/modelcard",
      "slot_uri": "https://w3id.org/linkml/modelcard/path",
      "owner": "ModelDetails",
      "domain_of": [
        "ModelDetails"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
